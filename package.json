{
  "name": "snapup-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:customer": "npm run dev --workspace=@snapup/customer-web",
    "dev:admin": "npm run dev --workspace=@snapup/admin-web",
    "build:customer": "npm run build --workspace=@snapup/customer-web",
    "build:admin": "npm run build --workspace=@snapup/admin-web"
  },
  "devDependencies": {}
}
